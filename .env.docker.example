# Optional overrides for docker compose (copy to .env in repo root)
SERVER_PORT=8070
FRONTEND_PORT=8080

# Baked into frontend image at build time — must be reachable from the user's browser
VITE_API_URL=http://localhost:8070/api
VITE_FRONTEND_DOMAIN=localhost:8080
VITE_BACKEND_DOMAIN=localhost:8070

# Dokploy production build args (set in Dokploy UI, not compose):
# VITE_API_URL=https://backend.orewire.com/api
# VITE_FRONTEND_DOMAIN=orewire.com
# VITE_BACKEND_DOMAIN=backend.orewire.com
