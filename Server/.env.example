# Domain Configuration (Production)
FRONTEND_DOMAIN=orewire.com
BACKEND_DOMAIN=backend.orewire.com
# Docker / Dokploy: use 8070 (see Server/Dockerfile). Local node dev may use 3000–3002.
PORT=8070

# Database
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Paths — local staging for scraped PDFs (uploaded to S3 when AWS_S3_ENABLED=true)
DOWNLOADS_DIR=./data/downloads
COOKIE_FILE=./data/cookies.json

# Browser scrapers (SEDAR+, ASX, CSE)
HEADLESS=true
MAX_PAGES=50
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36
TIMEZONE=America/Toronto
LOCALE=en-US

# AWS S3 object storage (filings PDFs) — required for production
# AWS_S3_ENABLED=true
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=eu-north-1
# AWS_S3_BUCKET=orewire-filings
# AWS_S3_PUBLIC_BASE_URL=https://orewire-filings.s3.eu-north-1.amazonaws.com
# STORAGE_FILING_PREFIX=filings
# AWS_S3_UPLOAD_DELAY_MS=75
# Keep bucket private and use presigned URLs (recommended — lower risk, same egress cost as public):
# AWS_S3_PRESIGNED_URLS=true
# AWS_S3_PRESIGN_EXPIRES_SEC=3600
#
# pdf_path in DB uses s3:key (stable). GET /api/filings/:id/document returns a presigned redirect.
# Test S3: node scripts/test-aws-s3-connection.js
# Admin UI: /admin/storage.html

# Browser proxies — managed in Admin → Proxies (browser_proxies table).
# One-time seed from legacy .env: node scripts/seed-initial-proxies.js

# Ollama AI — managed in Admin → AI (ai_providers table).
# One-time seed from legacy .env: node scripts/seed-ollama-from-env.js

# Usage event logs (AI + proxy) — retained 3 days by default
# USAGE_LOG_RETENTION_DAYS=3
# USAGE_LOG_PRUNE_CRON=15 4 * * *
# USAGE_LOG_PRUNE_ENABLED=false

# OreWire Relay — interactive browser pool (size = enabled proxies + 1 direct)
# RELAY_ENABLED=true
# RELAY_AUTO_START=1
# RELAY_HEADLESS=true   # use true in Docker/Dokploy (headed mode auto-disabled without DISPLAY)
# RELAY_VIEW_SECRET=generate_a_long_random_string
RELAY_BASE_URL=https://backend.orewire.com

# Admin Panel Password Protection
ADMIN_PASSWORD=your_admin_password

# Email (Resend) — verify no-reply@orewire.com in Resend dashboard
# AUTH_FROM_EMAIL: OTP, welcome, and Morning Brief subscribe confirmation
RESEND_API_KEY=your_resend_api_key
AUTH_FROM_EMAIL=OreWire <no-reply@orewire.com>
APP_URL=https://orewire.com
# Optional email link overrides
# EMAIL_FEED_URL=https://orewire.com/
# EMAIL_WATCHLIST_URL=https://orewire.com/watchlist
# EMAIL_PREFERENCES_URL=https://orewire.com/profile
# EMAIL_X_URL=https://x.com/Orewirenews
# EMAIL_LINKEDIN_URL=https://www.linkedin.com/company/orewire/
# EMAIL_INSTAGRAM_URL=https://www.instagram.com/orewirenews

# Daily morning briefing (Resend)
BRIEFING_FROM_EMAIL=OreWire Briefing <briefing@orewire.com>
BRIEFING_CRON=30 7 * * *
BRIEFING_TIMEZONE=America/Toronto
# BRIEFING_CRON_ENABLED=false
# BRIEFING_SEND_SECRET=your_secret_for_POST_api_briefing_send-now
# BRIEFING_SEND_DELAY_MS=200

# Watchlist news alerts (Resend) — one email per news item per watchlisted company
ALERTS_FROM_EMAIL=OreWire Alerts <alerts@orewire.com>
# WATCHLIST_NEWS_CRON=*/10 * * * *
# WATCHLIST_NEWS_CRON_ENABLED=false
# WATCHLIST_NEWS_SEND_DELAY_MS=150

# Watchlist filing alerts — morning batch (last 24h), from alerts@orewire.com
# WATCHLIST_FILING_CRON=35 7 * * *
# WATCHLIST_FILING_CRON_ENABLED=false
# WATCHLIST_FILING_LOOKBACK_HOURS=24
# WATCHLIST_FILING_SEND_DELAY_MS=200