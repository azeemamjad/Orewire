# Domain Configuration (Production)
BACKEND_DOMAIN=backend.orewire.com

# Browser
# Set to false to watch the browser in action (useful for debugging)
HEADLESS=true

# Proxy — use format: http://host:port or socks5://host:port
PROXY_SERVER=http://proxy.example.com:8080
PROXY_USERNAME=myuser
PROXY_PASSWORD=mypassword

# Where downloaded PDFs are saved (relative or absolute path)
DOWNLOAD_DIR=./downloads

# Human-like behaviour
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36
TIMEZONE=America/Toronto
LOCALE=en-US

# Cookie persistence (keeps session warm across runs)
COOKIE_FILE=./data/cookies.json

# Pagination — how many result pages to scrape (each page ~30 docs)
MAX_PAGES=50

# AI Analysis — Ollama
OLLAMA_HOST=https://ollama.com
OLLAMA_API_KEY=your_api_key
OLLAMA_MODEL=kimi-k2.6:cloud