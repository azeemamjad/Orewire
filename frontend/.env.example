# Domain Configuration (Production)
VITE_FRONTEND_DOMAIN=orewire.com
VITE_BACKEND_DOMAIN=backend.orewire.com

# API URL — REQUIRED for production builds (see below)
VITE_API_URL=https://backend.orewire.com/api

# ── Dokploy / Docker ─────────────────────────────────────────────────────────
# VITE_* values are baked in at BUILD time (npm run build), NOT at container runtime.
# In Dokploy → frontend app → Build → set **Build Arguments** (not only Environment):
#
#   VITE_API_URL=https://backend.orewire.com/api
#   VITE_FRONTEND_DOMAIN=orewire.com
#   VITE_BACKEND_DOMAIN=backend.orewire.com
#
# If VITE_API_URL is omitted but VITE_BACKEND_DOMAIN is set at build time,
# the app derives https://{VITE_BACKEND_DOMAIN}/api automatically.
#
# After changing any VITE_* value, rebuild and redeploy the frontend image.
